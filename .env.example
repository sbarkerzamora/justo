# AI provider selector.
# Use "openrouter" by default. Change to "nvidia" to route chat through NVIDIA temporarily.
AI_PROVIDER=openrouter

# OpenRouter provider config
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini

# NVIDIA provider config
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/nemotron-3-super-120b-a12b
NVIDIA_TEMPERATURE=1
NVIDIA_TOP_P=0.95
NVIDIA_MAX_OUTPUT_TOKENS=16384
NVIDIA_THINKING_ENABLED=false
NVIDIA_REASONING_BUDGET=16384

# Optional app metadata
NEXT_PUBLIC_APP_NAME=Justo

# Site URL for SEO (canonical, hreflang, sitemap)
# Override in production: NEXT_PUBLIC_SITE_URL=https://justo.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Plausible Analytics (optional)
# Domain must match the site configured in your self-hosted Plausible instance.
# Endpoint must point to your self-hosted /api/event URL. Leave disabled by default.
NEXT_PUBLIC_PLAUSIBLE_ENABLED=false
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_ENDPOINT=

# Upstash Redis for rate limiting and corpus caching
# Required in production. Get free credentials at https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Retention days for anonymous settlement stats (default 90)
STATS_RETENTION_DAYS=90
