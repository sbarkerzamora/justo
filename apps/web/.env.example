# Justo — Environment Variables
# Copy this file to .env.local and fill in the values.

# Site URL (required)
# Used for canonical URLs and OG images.
SITE_URL=https://justo.example.com
NEXT_PUBLIC_SITE_URL=https://justo.example.com

# AI Provider — OpenRouter (recommended)
# Sign up at https://openrouter.ai and get an API key.
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.5-flash-preview-04-17-25

# AI Provider — NVIDIA NIM (alternative)
# Sign up at https://build.nvidia.com and get an API key.
# NVIDIA_API_KEY=nvapi-...
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_MODEL=nvidia/llama-3.1-nemotron-ultra-253b-v1
# NVIDIA_TEMPERATURE=0.3
# NVIDIA_TOP_P=0.95
# NVIDIA_MAX_OUTPUT_TOKENS=8192
# NVIDIA_THINKING_ENABLED=false
# NVIDIA_REASONING_BUDGET=4096

# AI Provider — Generic (set AI_PROVIDER to "nvidia" | "openrouter")
AI_PROVIDER=openrouter

# Upstash Redis (optional; recommended for rate limiting and anonymous stats)
# Sign up at https://upstash.com and create a Redis database.
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# Upstash Vector (RAG del corpus legal en /api/chat)
# Crear indice en https://console.upstash.com -> Vector -> Create Index
# Usar "Integrated Embeddings" para mandar texto crudo desde la ingesta.
UPSTASH_VECTOR_REST_URL=https://...upstash.io
UPSTASH_VECTOR_REST_TOKEN=...

# Statistics retention (optional, default 90 days)
# STATS_RETENTION_DAYS=90

# Plausible Analytics (optional)
# NEXT_PUBLIC_PLAUSIBLE_ENABLED=false
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=justo.example.com
# NEXT_PUBLIC_PLAUSIBLE_ENDPOINT=https://plausible.example.com

# Telegram Bot (optional)
# NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=justo_bot
# TELEGRAM_BOT_TOKEN=...
