{
  "name": "justo",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=22.6.0",
    "pnpm": ">=10.18.3",
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "pnpm --filter @justo/web dev",
    "dev:turbo": "pnpm --filter @justo/web dev:turbo",
    "build": "pnpm --filter @justo/web build",
    "start": "pnpm --filter @justo/web start",
    "lint": "pnpm --filter @justo/web lint",
    "test": "bun test apps packages",
    "format": "prettier --write \"apps/**/*.{ts,tsx}\" \"packages/**/*.{ts,tsx}\"",
    "typecheck": "pnpm --filter @justo/web typecheck",
    "ingest": "pnpm --filter @justo/tools exec tsx scripts/ingest.ts",
    "ingest:reset": "pnpm --filter @justo/tools exec tsx scripts/ingest.ts --reset"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bun": "^1.3.2",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shadcn": "^4.7.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "workspaces": [
    ".",
    "apps/*",
    "packages/*"
  ]
}
